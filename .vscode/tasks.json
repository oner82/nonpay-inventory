{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "local server: auth_shell",
      "type": "shell",
      "command": "python3",
      "args": [
        "-m",
        "http.server",
        "5177"
      ],
      "isBackground": true,
      "problemMatcher": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "check: javascript syntax",
      "type": "shell",
      "command": "node",
      "args": [
        "--check",
        "auth_shell.js"
      ],
      "problemMatcher": []
    }
  ]
}
